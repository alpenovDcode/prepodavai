// Prisma Schema для PrepodavAI
// Миграция с Chatium Heap на PostgreSQL

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Пользователи приложения
model AppUser {
  id                    String    @id @default(uuid())
  userHash              String?   @unique
  source                String? // 'web' | 'telegram' | 'max'
  telegramId            String?   @unique
  maxId                 String?   @unique
  chatId                String? // Legacy: ID чата (Telegram или MAX — устарело, используй telegramChatId/maxChatId)
  telegramChatId        String? // Chat ID в Telegram для отправки результатов
  maxChatId             String? // Chat ID в MAX для отправки результатов
  username              String?
  apiKey                String?   @unique
  firstName             String?
  lastName              String?
  phone                 String?
  email                 String?
  bio                   String?
  subject               String? // Предмет преподавания
  grades                String? // Классы (например: "5–9 классы")
  avatar                String?
  notifyNewCourse       Boolean   @default(true)
  notifyStudentProgress Boolean   @default(false)
  notifyWeeklyReport    Boolean   @default(true)
  phoneVerified         Boolean   @default(false)
  lastAccessAt          DateTime?
  lastTelegramAppAccess DateTime?
  lastMaxAppAccess      DateTime?
  passwordHash          String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // UTM-атрибуция (маркетинговые ссылки)
  utmSource      String? // instagram, telegram, vk, etc.
  utmMedium      String? // bio, story, post, direct
  utmCampaign    String? // название кампании
  utmContent     String? // вариант контента
  utmTerm        String? // ключевое слово
  utmLandingPage String? // страница, на которую попал лид
  utmLinkId      String? // ссылка на UtmLink

  // Реферальная система
  referredByCode     String? // Код, по которому пришёл пользователь
  referralCodes      ReferralCode[]
  referralMilestones ReferralMilestone[]

  // Связи
  subscription         UserSubscription?
  generations          UserGeneration[]
  lessons              Lesson[]
  creditTransactions   CreditTransaction[]
  systemLogs           SystemLog[]
  classes              Class[]
  linkTokens           LinkToken[]
  onboardingQuestSteps OnboardingQuestStep[]
  payments             Payment[]
  studentInvites       StudentInvite[]
  diaryEntries         TeacherDiaryEntry[]
  botUser              BotUser?
  analyticsEvents      AnalyticsEvent[]
  calendarEvents       CalendarEvent[]

  @@index([telegramId])
  @@index([maxId])
  @@index([chatId])
  @@index([userHash])
  @@index([apiKey])
  @@index([utmSource])
  @@index([utmCampaign])
  @@index([utmLinkId])
  @@map("app_users")
}

// Тарифные планы
model SubscriptionPlan {
  id                   String   @id @default(uuid())
  planKey              String   @unique // 'starter', 'pro', 'business'
  planName             String
  monthlyCredits       Int
  price                Decimal  @db.Decimal(10, 2)
  currency             String   @default("RUB")
  allowOverage         Boolean  @default(false)
  overageCostPerCredit Decimal? @db.Decimal(10, 2)
  features             String[] // Array of features
  isActive             Boolean  @default(true)

  // Лимиты по классам и ученикам (null = безлимит)
  maxStudents Int?
  maxClasses  Int?

  // Лимиты использования функций в месяц (null = безлимит, 0 = недоступно)
  maxPhotosessionPerMonth Int?
  maxImageGenPerMonth     Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  subscriptions UserSubscription[]

  @@map("subscription_plans")
}

// Подписки пользователей
model UserSubscription {
  id                 String   @id @default(uuid())
  userId             String   @unique
  planId             String
  status             String // 'active', 'inactive', 'expired'
  creditsBalance     Int      @default(0)
  extraCredits       Int      @default(0)
  creditsUsed        Int      @default(0)
  overageCreditsUsed Int      @default(0)
  startDate          DateTime
  endDate            DateTime
  autoRenew          Boolean  @default(true)
  cpSubscriptionId   String? // CloudPayments SubscriptionId для рекуррентных
  cpCardToken        String? // Токен карты для повторных списаний

  // Счётчики использования функций в текущем месяце
  photosessionUsedThisMonth Int @default(0)
  imageGenUsedThisMonth     Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  user         AppUser             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan    @relation(fields: [planId], references: [id])
  transactions CreditTransaction[]

  @@map("user_subscriptions")
}

// Стоимость операций
model CreditCost {
  id                 String   @id @default(uuid())
  operationType      String   @unique
  operationName      String
  creditCost         Int
  description        String?
  isActive           Boolean  @default(true)
  isUnderMaintenance Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("credit_costs")
}

// Транзакции Токенов
model CreditTransaction {
  id                  String   @id @default(uuid())
  userId              String
  subscriptionId      String
  type                String // 'debit', 'credit', 'grant', 'refund', 'monthly_reset'
  amount              Int
  balanceBefore       Int
  balanceAfter        Int
  operationType       String? // Тип операции генерации
  generationRequestId String?
  description         String?
  metadata            Json? // Дополнительные данные
  createdAt           DateTime @default(now())

  // Связи
  user         AppUser          @relation(fields: [userId], references: [id])
  subscription UserSubscription @relation(fields: [subscriptionId], references: [id])

  @@index([userId])
  @@index([subscriptionId])
  @@index([generationRequestId])
  @@map("credit_transactions")
}

// Запросы генерации (старая таблица для совместимости)
model GenerationRequest {
  id        String   @id @default(uuid())
  userId    String
  type      String // Тип генерации
  params    Json? // Параметры запроса
  status    String // 'pending', 'completed', 'failed'
  result    Json? // Результат генерации
  error     String?
  model     String?
  metadata  Json? // Дополнительные данные (например, replicatePredictionId)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  userGeneration UserGeneration?

  @@index([userId])
  @@index([status])
  @@map("generation_requests")
}

// Генерации пользователей (новая таблица с детальными данными)
model UserGeneration {
  id                  String    @id @default(uuid())
  userId              String
  generationType      String // Тип генерации
  status              String // 'pending', 'completed', 'failed'
  title               String? // Пользовательское название генерации (переименование в истории)
  inputParams         Json? // Параметры запроса
  outputData          Json? // Полный результат генерации
  errorMessage        String?
  model               String?
  generationRequestId String    @unique
  sentToTelegram      Boolean   @default(false)
  telegramSentAt      DateTime?
  sentToMax           Boolean   @default(false)
  maxSentAt           DateTime?
  initiatedSource     String? // 'web' | 'telegram_bot' | 'max_bot' — откуда инициирована генерация
  tokensUsed          Int? // Количество потраченных токенов
  creditCost          Int? // Итоговая стоимость Токенов
  lessonId            String?
  folder              String?   // Пользовательская папка (строка, не FK)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  // Связи
  user              AppUser           @relation(fields: [userId], references: [id])
  generationRequest GenerationRequest @relation(fields: [generationRequestId], references: [id])
  lesson            Lesson?           @relation(fields: [lessonId], references: [id])
  assignments       Assignment[]

  @@index([userId])
  @@index([status])
  @@index([generationType])
  @@index([generationRequestId])
  @@index([lessonId])
  @@map("user_generations")
}

// Уроки (группировка генераций)
model Lesson {
  id              String    @id @default(uuid())
  userId          String
  title           String // Обычно совпадает с темой
  topic           String
  grade           String?
  duration        Int? // legacy
  // Расписание урока (M3)
  scheduledAt     DateTime?
  durationMinutes Int?
  classId         String?
  notes           String?
  // Теги/библиотека (M4)
  tags            String[]  @default([])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Связи
  user           AppUser          @relation(fields: [userId], references: [id])
  class          Class?           @relation(fields: [classId], references: [id], onDelete: SetNull)
  generations    UserGeneration[]
  assignments    Assignment[]
  calendarEvents CalendarEvent[]

  @@index([userId])
  @@index([classId])
  @@index([scheduledAt])
  @@map("lessons")
}

// Системные логи
model SystemLog {
  id                  String   @id @default(uuid())
  level               String // 'info', 'warn', 'error'
  category            String // 'telegram_send', 'generation', 'user_auth', 'webhook'
  message             String
  data                Json?
  userId              String?
  generationRequestId String?
  timestamp           DateTime @default(now())

  // Связи
  user AppUser? @relation(fields: [userId], references: [id])

  @@index([level])
  @@index([category])
  @@index([userId])
  @@index([timestamp])
  @@map("system_logs")
}

// Планы уроков (дополнительная таблица)
model LessonPlan {
  id        String   @id @default(uuid())
  userId    String
  subject   String
  topic     String
  level     String
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("lesson_plans")
}

// Материалы (дополнительная таблица)
model Material {
  id        String   @id @default(uuid())
  userId    String
  title     String
  type      String
  content   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("materials")
}

// Чаты ИИ-учителя
model AiChat {
  id        String        @id @default(uuid())
  userId    String
  title     String        @default("Новый диалог")
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]

  @@index([userId])
  @@map("ai_chats")
}

// Сообщения чата
model ChatMessage {
  id        String   @id @default(uuid())
  chatId    String?
  userId    String
  role      String // 'user', 'assistant'
  content   String
  model     String?
  metadata  Json?
  createdAt DateTime @default(now())

  chat AiChat? @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([chatId])
  @@map("chat_messages")
}

// Коды верификации
model VerificationCode {
  id        String   @id @default(uuid())
  userId    String?
  phone     String
  code      String
  type      String // 'sms', 'email'
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([code])
  @@map("verification_codes")
}

// Классы (Группы учеников)
model Class {
  id          String   @id @default(uuid())
  teacherId   String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  teacher        AppUser             @relation(fields: [teacherId], references: [id])
  students       Student[]
  assignments    Assignment[]
  invites        StudentInvite[]
  lessons        Lesson[]
  diaryEntries   TeacherDiaryEntry[]
  calendarEvents CalendarEvent[]

  @@index([teacherId])
  @@map("classes")
}

// Ученики
model Student {
  id           String   @id @default(uuid())
  classId      String
  name         String
  email        String?
  phone        String? // Опциональный номер телефона ученика
  passwordHash String? // Хэш пароля для входа по email+паролю
  accessCode   String?  @unique // Устаревший метод входа (по коду)
  avatar       String?
  notes        String? // AI характеристика или заметки учителя
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  referredByCode String? // Если ученик пришёл по реферальной ссылке
  status         String  @default("active") // 'active' | 'pending' (ожидает подтверждения учителя)

  class                Class                @relation(fields: [classId], references: [id], onDelete: Cascade)
  assignments          Assignment[]
  submissions          Submission[]
  diaryEntries         TeacherDiaryEntry[]
  gamification         StudentGamification?
  unlockedAchievements StudentAchievement[]
  xpEvents             XpEvent[]
  calendarEvents       CalendarEvent[]

  @@index([classId])
  @@map("students")
}

// Пригласительные ссылки для учеников
model StudentInvite {
  id        String    @id @default(uuid())
  token     String    @unique
  teacherId String
  classId   String?
  expiresAt DateTime?
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  teacher AppUser @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class?  @relation(fields: [classId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([classId])
  @@map("student_invites")
}

// Назначения (Задания)
model Assignment {
  id           String    @id @default(uuid())
  classId      String?
  studentId    String?
  lessonId     String
  generationId String? // Optional: assign a specific generation instead of the whole lesson
  status       String    @default("assigned") // assigned, submitted, graded
  dueDate      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  class       Class?          @relation(fields: [classId], references: [id], onDelete: Cascade)
  student     Student?        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson      Lesson          @relation(fields: [lessonId], references: [id])
  generation  UserGeneration? @relation(fields: [generationId], references: [id])
  submissions Submission[]

  @@index([classId])
  @@index([studentId])
  @@index([lessonId])
  @@index([generationId])
  @@map("assignments")
}

// Решения (Ответы учеников)
model Submission {
  id           String   @id @default(uuid())
  assignmentId String
  studentId    String
  content      String? // Текст или URL
  attachments  Json? // Файлы
  formData     Json? // Интерактивные ответы из HTML-задания { [generationId]: { fieldId: value } }
  grade        Int?
  feedback     String? // AI или комментарий учителя
  status       String   @default("submitted") // submitted, graded
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  assignment Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student    Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([assignmentId])
  @@index([studentId])
  @@map("submissions")
}

// Уведомления
model Notification {
  id        String   @id @default(uuid())
  userId    String // ID получателя (AppUser.id для учителя, Student.id для ученика)
  userType  String // 'teacher' | 'student'
  type      String // 'submission_received' | 'submission_graded'
  title     String
  message   String
  isRead    Boolean  @default(false)
  metadata  Json? // { assignmentId, submissionId, studentName, grade }
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([userType, userId])
  @@map("notifications")
}

// ========== РЕФЕРАЛЬНАЯ СИСТЕМА ==========

// Реферальные коды
model ReferralCode {
  id         String   @id @default(uuid())
  userId     String
  userType   String // 'teacher' | 'student'
  code       String   @unique
  isActive   Boolean  @default(true)
  usageCount Int      @default(0)
  maxUsages  Int? // null = безлимитно
  createdAt  DateTime @default(now())

  user      AppUser    @relation(fields: [userId], references: [id], onDelete: Cascade)
  referrals Referral[]

  @@index([userId])
  @@index([code])
  @@map("referral_codes")
}

// Факт реферала
model Referral {
  id                      String    @id @default(uuid())
  referralCodeId          String
  referrerUserId          String // Кто пригласил (AppUser.id)
  referrerType            String // 'teacher' | 'student'
  referredUserId          String // Кого пригласили (AppUser.id или Student.id)
  referredType            String // 'teacher' | 'student'
  referralType            String // 'teacher_teacher' | 'teacher_student' | 'student_student'
  status                  String    @default("registered") // 'registered' | 'activated' | 'converted'
  rewardGranted           Boolean   @default(false)
  conversionRewardGranted Boolean   @default(false)
  activatedAt             DateTime?
  convertedAt             DateTime?
  metadata                Json? // { submissionsCount, classId, ... }
  createdAt               DateTime  @default(now())

  referralCode ReferralCode @relation(fields: [referralCodeId], references: [id])

  @@unique([referredUserId, referredType])
  @@index([referrerUserId])
  @@index([referralCodeId])
  @@index([referralType])
  @@map("referrals")
}

// Milestone-бонусы за рефералов
model ReferralMilestone {
  id        String   @id @default(uuid())
  userId    String
  milestone String // 'students_5' | 'students_10' | 'teachers_3' | 'teachers_8'
  reward    Int // Сколько Токенов начислено
  grantedAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, milestone])
  @@index([userId])
  @@map("referral_milestones")
}

// Токены для привязки платформ (Telegram/Max) к web-аккаунту
model LinkToken {
  id         String   @id @default(uuid())
  token      String   @unique // 8-символьный hex (отображается пользователю)
  userId     String // AppUser, который инициировал привязку
  platform   String // 'telegram' | 'max'
  status     String   @default("pending") // 'pending' | 'completed' | 'expired'
  linkedId   String? // telegramId / maxId после подтверждения
  linkedName String? // @username для отображения в UI
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("link_tokens")
}

// ========== ОНБОРДИНГ КВЕСТ ==========

// Шаги онбординг-квеста новых пользователей
model OnboardingQuestStep {
  id          String   @id @default(uuid())
  userId      String
  step        String // 'FIRST_GENERATION' | 'SECOND_TYPE_GENERATION' | 'SHARED_REFERRAL_LINK' | 'FIRST_REFERRAL_ACTIVATED' | 'SECOND_REFERRAL_ACTIVATED'
  completedAt DateTime @default(now())

  user AppUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, step])
  @@index([userId])
  @@map("onboarding_quest_steps")
}

// ========== UTM-ТРЕКИНГ ==========

// Маркетинговые ссылки с UTM-параметрами
model UtmLink {
  id            String   @id @default(uuid())
  name          String // Название для себя (напр. "Instagram bio апрель")
  socialNetwork String // 'instagram' | 'telegram' | 'vk' | 'youtube' | 'tiktok' | 'whatsapp' | 'other'
  utmSource     String // instagram, telegram, vk, ...
  utmMedium     String // bio, story, post, reel, direct, ...
  utmCampaign   String // название кампании
  utmContent    String? // вариант контента (A/B)
  utmTerm       String? // ключевое слово
  baseUrl       String   @default("https://prepodavai.ru")
  fullUrl       String // итоговая ссылка с UTM
  clicks        Int      @default(0) // переходы
  registrations Int      @default(0) // регистрации по этой ссылке
  bonusTokens   Int      @default(0) // токены за регистрацию по ссылке
  linkTtl       String   @default("always") // 'always' | '48h' | '24h'
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([socialNetwork])
  @@index([utmCampaign])
  @@map("utm_links")
}

// Умная короткая ссылка-редирект: prepodavai.ru/g/<slug> → targetUrl.
// При клике инкрементим clickCount и пишем строку в SmartLinkClick (для разбора).
// UTM-поля при редиректе аппендятся к targetUrl, autoTags применяются к
// пользователю при первом касании (если узнаём — anon-cookie / lid в URL /
// /start payload в Telegram-боте).
model SmartLink {
  id          String   @id @default(uuid())
  slug        String   @unique // [A-Za-z0-9_-]{1,48}, например "ig-bio-april"
  name        String // человекочитаемое название
  targetUrl   String // куда редиректит (https://t.me/bot?start=... или landing)
  description String?

  // Опциональные UTM-оверрайды: при редиректе аппендятся к targetUrl как
  // ?utm_source=...&utm_medium=...&utm_campaign=... — те же поля, что в UtmLink.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?

  // Авто-теги, навешиваемые при первом клике (для сегментации в маркетинге).
  autoTags    String[] @default([])

  // Быстрые счётчики — инкрементятся в редиректе, чтобы не агрегировать SQL
  // на каждый список.
  clickCount     Int @default(0) // всего кликов (uniq не считаем тут)
  uniqueClicks   Int @default(0) // уникальных по anonId/userId
  registrations  Int @default(0) // регистраций после клика

  isActive    Boolean   @default(true)
  expiresAt   DateTime? // null = бессрочная

  // Привязка к воронке (опционально). Если есть — ТГ-бот возьмёт welcome-
  // конфиг из этой воронки при /start <token>. Если нет — дефолт.
  funnelId   String?
  funnel     Funnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clicks      SmartLinkClick[]

  @@index([funnelId])
  @@map("smart_links")
}

model SmartLinkClick {
  id        String   @id @default(uuid())
  linkId    String
  link      SmartLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  // Идентификация: либо залогиненный userId (если cookie уже есть),
  // либо анонимный anonId (генерим в редиректе и кладём в cookie).
  userId    String?
  anonId    String?

  ip        String?
  userAgent String?
  referer   String?
  country   String?

  createdAt DateTime @default(now())

  @@index([linkId, createdAt])
  @@index([userId])
  @@index([anonId])
  @@map("smart_link_clicks")
}

// Платежи через CloudPayments
model Payment {
  id               String    @id @default(uuid())
  userId           String
  planKey          String
  amount           Decimal   @db.Decimal(10, 2)
  currency         String    @default("RUB")
  status           String // 'pending', 'completed', 'failed'
  cpTransactionId  String? // TransactionId от CloudPayments
  cpSubscriptionId String? // SubscriptionId (для рекуррентных)
  cpToken          String? // Токен карты (для повторных списаний)
  invoiceId        String    @unique // Наш внутренний ID заказа
  isRecurrent      Boolean   @default(false)
  consentGivenAt   DateTime? // Когда пользователь поставил чекбокс согласия
  consentIp        String? // IP-адрес в момент согласия
  consentUserAgent String? // User-Agent браузера в момент согласия
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user AppUser @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([invoiceId])
  @@index([cpTransactionId])
  @@index([cpSubscriptionId])
  @@map("payments")
}

// Загруженные файлы
model UploadedFile {
  id        String   @id @default(uuid())
  hash      String   @unique
  userId    String // Can be AppUser.id or Student.id
  filename  String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([hash])
  @@map("uploaded_files")
}

// ========== ДНЕВНИК УЧИТЕЛЯ ==========
// Журнал проведённых уроков с возможностью прикрепить запись (Яндекс.Диск)
// и автоматически прогнать через методический видеоанализ.
model TeacherDiaryEntry {
  id                   String   @id @default(uuid())
  teacherId            String
  date                 DateTime @default(now())
  classId              String?
  studentId            String?
  topic                String? // Тема урока
  goals                String? // Цели урока
  covered              String? // Что пройдено
  homework             String? // Домашнее задание
  notes                String? // Заметки / наблюдения
  recordingUrl         String? // Ссылка на запись (Yandex.Disk)
  analysisGenerationId String? // generationRequestId из UserGeneration — методический анализ
  aiFilledFields       String[] @default([]) // Какие поля заполнены AI (topic/goals/covered/homework/notes)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  teacher AppUser  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class?   @relation(fields: [classId], references: [id], onDelete: SetNull)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@index([teacherId])
  @@index([classId])
  @@index([studentId])
  @@index([date])
  @@map("teacher_diary_entries")
}

// Пользователи чат-ботов (Telegram и MAX)
model BotUser {
  id String @id @default(uuid())

  // Связь с аккаунтом платформы (если есть)
  appUserId String?  @unique
  appUser   AppUser? @relation(fields: [appUserId], references: [id], onDelete: SetNull)

  // Идентификаторы мессенджеров
  telegramId String? @unique
  maxId      String? @unique

  // Профиль (из мессенджера)
  firstName String?
  lastName  String?
  username  String?
  email     String?

  // Статус: 'pending' | 'registered' | 'linked'
  registrationStatus String  @default("pending")
  // Источник: 'telegram_bot' | 'max_bot' | 'linked_telegram' | 'linked_max'
  source             String?

  // Независимые бот-кредиты (редактируются напрямую в БД)
  botCredits Int @default(100)

  // Статистика
  totalGenerations     Int       @default(0)
  generationsThisMonth Int       @default(0)
  lastGenerationAt     DateTime?
  lastActiveAt         DateTime?

  // Атрибуция: откуда пришёл в бот
  startPayload String? // raw payload из /start (deep-link параметр)
  utmSource    String? // распарсенный источник (instagram, vk, telegram_channel, и т.д.)
  utmMedium    String?
  utmCampaign  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Связи
  botCreditTransactions BotCreditTransaction[]

  @@index([telegramId])
  @@index([maxId])
  @@index([appUserId])
  @@map("bot_users")
}

// История транзакций бот-кредитов
model BotCreditTransaction {
  id             String   @id @default(uuid())
  botUserId      String
  botUser        BotUser  @relation(fields: [botUserId], references: [id], onDelete: Cascade)
  amount         Int // отрицательное = списание, положительное = начисление
  balanceBefore  Int
  balanceAfter   Int
  reason         String // 'initial_grant' | 'generation_deduct' | 'generation_refund' | 'admin_grant' | 'admin_set'
  generationType String? // тип генерации, если reason = generation_*
  description    String?
  createdAt      DateTime @default(now())

  @@index([botUserId])
  @@index([createdAt])
  @@map("bot_credit_transactions")
}

// ────────────────────────────────────────────────────────────────────────────
// Всплывающие модальные окна на главной странице (опросы, анонсы, реклама).
// Создаются админом через /admin/popups. На фронте показывается активный popup
// с наибольшим priority через N секунд после загрузки dashboard.
// ────────────────────────────────────────────────────────────────────────────
model DashboardPopup {
  id           String    @id @default(uuid())
  title        String? // Заголовок модалки (опционально)
  body         String // Текст. Поддерживает переносы строк и автоопределение URL.
  ctaText      String? // Подпись основной кнопки. Если null — только «Закрыть».
  ctaUrl       String? // URL для основной кнопки.
  delaySeconds Int       @default(5) // Задержка показа после загрузки страницы.
  isActive     Boolean   @default(true)
  priority     Int       @default(0) // Чем больше — тем приоритетнее, если активно несколько.
  startsAt     DateTime?
  endsAt       DateTime?
  createdBy    String? // appUser.id админа
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  dismissals DashboardPopupDismissal[]

  @@index([isActive, priority])
  @@map("dashboard_popups")
}

// Кто и когда закрыл popup — чтобы не показывать одному пользователю повторно.
model DashboardPopupDismissal {
  id        String   @id @default(uuid())
  popupId   String
  userId    String
  createdAt DateTime @default(now())

  popup DashboardPopup @relation(fields: [popupId], references: [id], onDelete: Cascade)

  @@unique([popupId, userId])
  @@index([userId])
  @@map("dashboard_popup_dismissals")
}

// ────────────────────────────────────────────────────────────────────────────
// Глобальные системные настройки. Сейчас используется для maintenance-mode
// («Ведутся технические работы»), но key/value-формат позволяет добавлять
// другие переключатели без миграций.
// Ключи:
//   maintenance.enabled  → 'true' / 'false'
//   maintenance.message  → текст заглушки для пользователей
// ────────────────────────────────────────────────────────────────────────────
model SystemSetting {
  key       String   @id
  value     String?
  updatedAt DateTime @updatedAt
  updatedBy String? // appUser.id админа

  @@map("system_settings")
}

// ========== АНАЛИТИКА И ВОРОНКИ (FUNNELS) ==========

/// Универсальный лог событий пользователя. Источник истины для всех воронок и когорт.
/// Записывается из:
///   — сервер: registerByEmail / generation_created / referral_used / tg_linked / channel_subscribed
///   — клиент: pageview / button_click / onboarding_step (через POST /analytics/track)
///   — бот: channel_subscribed (через chat_member webhook)
model AnalyticsEvent {
  id          String   @id @default(uuid())
  /// Анонимный ID из cookie (живёт до регистрации). После регистрации в userId
  /// ставится AppUser.id, anonId остаётся для склейки до-реги активности.
  anonId      String?
  userId      String? // null до регистрации
  /// Категория события: 'page_view' | 'click' | 'user_registered' | 'generation_created' | 'tg_linked' | ...
  eventType   String
  /// Дополнительный ключ внутри типа: для page_view — путь, для generation_created — тип генерации.
  eventName   String?
  /// Произвольная нагрузка: {generationType, sourceClass, durationMs, ...}
  payload     Json?
  /// UTM-атрибуция копируется на момент события (immutable). Если пользователь
  /// сменит источник в новой сессии — у нового события будут новые UTM.
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmContent  String?
  utmTerm     String?
  /// Идентификатор сессии (один день / одна вкладка). Для расчёта bounce.
  sessionId   String?
  /// Тех. срезы.
  userAgent   String?
  ipHash      String? // SHA-256 от IP — для DAU, не PII
  referer     String?
  createdAt   DateTime @default(now())

  user AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType, createdAt])
  @@index([userId, createdAt])
  @@index([anonId, createdAt])
  @@index([utmSource, createdAt])
  @@map("analytics_events")
}

/// Определение воронки. Создаётся админом в /admin/funnels.
model Funnel {
  id            String   @id @default(uuid())
  name          String
  description   String?
  /// Кто создал. Используется как owner для аудита, но смотреть могут все админы.
  ownerId       String?
  isActive      Boolean  @default(true)
  /// Дополнительный фильтр уровня воронки: '{"utmSource": "instagram"}' и т.д.
  /// Применяется ко всем шагам.
  globalFilters Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // ───── Welcome-конфиг для Telegram-бота ─────
  // Когда юзер кликает SmartLink, привязанную к этой воронке, и заходит в
  // ТГ-бот через t.me/?start=<token>, бот шлёт это сообщение вместо
  // дефолтного. Маркетолог может тестировать разные первые касания под
  // разные источники, не трогая код.
  //
  // Если поля пустые — бот использует дефолтное хардкодное приветствие.
  welcomeText               String?
  welcomeButtonLabel        String?
  /// Что делает кнопка: 'url' (открыть ссылку) | 'mini_app' (открыть Mini App) |
  /// 'check_subscription' (проверить подписку на канал).
  welcomeButtonAction       String?  @default("url")
  welcomeButtonUrl          String?
  /// Обязательный канал для подписки. Можно ID (-100xxx) или @username.
  subscriptionChannelId     String?
  /// Отображаемое название канала для текста: «Подпишись на @prepodavai».
  subscriptionChannelName   String?
  /// Сообщение, которое показываем когда юзер ещё не подписан.
  subscriptionPromptText    String?
  /// Сообщение после успешной проверки подписки.
  subscriptionSuccessText   String?

  steps     FunnelStep[]
  smartLinks SmartLink[]

  @@index([isActive])
  @@map("funnels")
}

/// Один шаг воронки.
/// При расчёте: user, попавший в шаг N, должен попасть в шаг N+1 не раньше шага N.
model FunnelStep {
  id             String   @id @default(uuid())
  funnelId       String
  /// Порядковый номер. 0 — точка входа.
  order          Int
  /// Человеко-читаемый заголовок: «Конверсия из реги в первую генерацию»
  label          String
  /// Какое событие из AnalyticsEvent.eventType должен совершить пользователь.
  /// Спец-значения:
  ///   'generation_created:nth=1' — первая генерация
  ///   'generation_created:nth=3' — третья (для N→M)
  eventType      String
  /// JSON-фильтр на payload и UTM. Пример:
  ///   {"payload.generationType": "worksheet"}
  ///   {"utmSource": "blogger_xxx"}
  eventFilters   Json?
  /// Если true — этот шаг используется как "якорь когорты" (дата отсчёта).
  /// Обычно первый шаг.
  isCohortAnchor Boolean  @default(false)
  createdAt      DateTime @default(now())

  funnel Funnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)

  @@unique([funnelId, order])
  @@index([funnelId])
  @@map("funnel_steps")
}

// ========== ГЕЙМИФИКАЦИЯ (PHASE 5 V2) ==========

// Состояние геймификации для одного ученика.
// Один Student = одна запись. Создаётся при первом действии.
model StudentGamification {
  id             String    @id @default(uuid())
  studentId      String    @unique
  // Опыт и уровень
  xp             Int       @default(0) // Накопленный опыт за всё время
  level          Int       @default(1) // Текущий уровень (вычислимо из xp, но кэшируем)
  // Streak
  streakDays     Int       @default(0) // Подряд дней активности
  bestStreakDays Int       @default(0) // Рекорд стрика
  lastActiveDate DateTime? // День последнего «check-in» (нормализован на 00:00 UTC)
  // Счётчики для ачивок
  submittedCount Int       @default(0)
  gradedCount    Int       @default(0)
  perfectCount   Int       @default(0) // Кол-во работ с максимальной оценкой
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_gamification")
}

// Каталог ачивок. Сидится миграцией.
model Achievement {
  key            String  @id // 'first-step', 'streak-7' и т.д.
  title          String // 'Первый шаг'
  description    String // 'Сдать первое задание'
  category       String  @default("general") // 'streak' | 'grade' | 'subject' | 'game' | 'social'
  // Условие — какое поле StudentGamification смотреть и какой порог.
  conditionField String // 'submittedCount' | 'streakDays' | 'perfectCount'
  conditionValue Int // 1, 7, 30, ...
  // Награда
  xpReward       Int     @default(50)
  // UI hint
  iconKey        String  @default("trophy") // 'flame', 'star', 'trophy', 'zap', 'book-open', ...
  color          String  @default("brand") // 'brand' | 'success' | 'warning' | 'danger' | 'info' | 'indigo'
  emoji          String  @default("🏆") // Эмодзи медали
  rarity         String  @default("common") // 'common' | 'rare' | 'epic' | 'legendary'
  // Порядок отображения
  sortOrder      Int     @default(0)
  isActive       Boolean @default(true)

  unlocked StudentAchievement[]

  @@map("achievements")
}

// Какие ачивки разблокировал конкретный ученик.
model StudentAchievement {
  id             String   @id @default(uuid())
  studentId      String
  achievementKey String
  unlockedAt     DateTime @default(now())

  student     Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementKey], references: [key], onDelete: Cascade)

  @@unique([studentId, achievementKey])
  @@index([studentId])
  @@map("student_achievements")
}

// Аудит-лог начисления опыта. Полезно для дебага и для UI «история XP».
model XpEvent {
  id        String   @id @default(uuid())
  studentId String
  amount    Int // Может быть отрицательным (штраф)
  reason    String // 'submission_created' | 'submission_graded_perfect' | 'streak_milestone_7' | 'achievement_unlock'
  metadata  Json? // { submissionId?, achievementKey?, ... }
  createdAt DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([createdAt])
  @@map("xp_events")
}

// ─── Календарь репетитора ──────────────────────────────────────────────
//
// CalendarEvent — единица расписания (урок, встреча, окно). Может быть
// связан с уроком/учеником/классом, но всё опционально (есть и «свои»
// события: встреча с родителями, перерыв, личное).
//
// Повторения хранятся как RFC-5545 RRULE-строка в RecurrenceRule.
// Чтобы перенести/удалить ОДНУ копию повтора — событие пересоздаётся
// как одиночное (origin = parent.id, recurrenceExdate += startAt).
//
// Источник истины для синхронизации с Google: googleEventId + lastSyncAt.
model CalendarEvent {
  id     String @id @default(uuid())
  userId String // владелец события (репетитор)

  // Время
  startAt DateTime
  endAt   DateTime
  allDay  Boolean  @default(false)

  // Содержимое
  title      String
  notes      String? // длинный комментарий
  location   String? // адрес для офлайна
  meetingUrl String? // ссылка для онлайна

  // Привязки (всё опционально)
  studentId String?
  classId   String?
  lessonId  String? // связь с Lesson (для материалов/ДЗ)
  subject   String? // предмет — копируем из урока для отображения

  // Тип/формат/статус
  eventType String  @default("lesson") // 'lesson' | 'meeting' | 'break' | 'personal'
  format    String  @default("online") // 'online' | 'offline' | 'hybrid'
  status    String  @default("planned") // 'planned' | 'completed' | 'cancelled'
  color     String? // hex для UI, иначе берём по предмету

  // Повторения
  recurrenceRuleId String?
  recurrenceExdate DateTime[] @default([]) // исключения для RRULE (move/delete одного occurrence)
  parentEventId    String? // если это «оторванное» повторение

  // Google Calendar sync (Phase 4)
  googleEventId    String?   @unique
  googleCalendarId String?
  lastSyncAt       DateTime?

  // Напоминания (Phase 3)
  remindersSent String[] @default([]) // ['24h', '1h', '10m']

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user           AppUser         @relation(fields: [userId], references: [id], onDelete: Cascade)
  student        Student?        @relation(fields: [studentId], references: [id], onDelete: SetNull)
  class          Class?          @relation(fields: [classId], references: [id], onDelete: SetNull)
  lesson         Lesson?         @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  recurrenceRule RecurrenceRule? @relation(fields: [recurrenceRuleId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
  @@index([studentId])
  @@index([classId])
  @@index([lessonId])
  @@index([status])
  @@map("calendar_events")
}

// Правило повторения по RFC-5545 (rrule).
// Пример: "FREQ=WEEKLY;BYDAY=TU,TH;UNTIL=20270601T000000Z"
model RecurrenceRule {
  id        String          @id @default(uuid())
  rrule     String // полная RRULE-строка
  createdAt DateTime        @default(now())
  events    CalendarEvent[]

  @@map("recurrence_rules")
}
